<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="003" author="prabhat">
        <createTable tableName="user_tenants">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="BIGINT"/>
            <column name="tenant_id" type="BIGINT"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="user_tenants"
                                 baseColumnNames="user_id"
                                 referencedTableName="users"
                                 referencedColumnNames="id"
                                 constraintName="fk_user_tenant_user"/>

        <addForeignKeyConstraint baseTableName="user_tenants"
                                 baseColumnNames="tenant_id"
                                 referencedTableName="tenants"
                                 referencedColumnNames="id"
                                 constraintName="fk_user_tenant_tenant"/>

        <addUniqueConstraint tableName="user_tenants"
                             columnNames="user_id, tenant_id"
                             constraintName="uk_user_tenant"/>
    </changeSet>

</databaseChangeLog>
